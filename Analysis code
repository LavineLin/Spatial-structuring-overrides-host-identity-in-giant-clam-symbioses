run_anosim_by_site_drop_small_groups <- function(physeq, site_var = "Site", group_var = "Species",
                                                 min_n_per_group = 2,
                                                 permutations = 999, method = "bray", binary = TRUE) {
  
  meta_all <- data.frame(sample_data(physeq))
  sites <- sort(unique(as.character(meta_all[[site_var]])))
  
  map_dfr(sites, function(st) {
    
    # 先切出該地點的樣本
    keep_samples0 <- rownames(meta_all)[meta_all[[site_var]] == st]
    ps0 <- prune_samples(keep_samples0, physeq)
    ps0 <- prune_taxa(taxa_sums(ps0) > 0, ps0)
    
    meta0 <- data.frame(sample_data(ps0))
    grp0  <- as.character(meta0[[group_var]])
    tab0  <- table(grp0)
    
    # 保留樣本數>=min_n_per_group 的群組
    keep_groups    <- names(tab0)[tab0 >= min_n_per_group]
    dropped_groups <- setdiff(names(tab0), keep_groups)
    
    # 用「樣本名」來篩掉小群（避免 subset_samples 的 NSE）
    keep_samples <- rownames(meta0)[meta0[[group_var]] %in% keep_groups]
    ps <- prune_samples(keep_samples, ps0)
    ps <- prune_taxa(taxa_sums(ps) > 0, ps)
    
    meta <- data.frame(sample_data(ps))
    grp  <- as.character(meta[[group_var]])
    
    if (length(unique(grp)) < 2) {
      return(tibble(
        Site = st,
        n_samples = nsamples(ps0),
        n_groups  = length(unique(grp0)),
        kept_groups = ifelse(length(keep_groups)==0, "", paste(keep_groups, collapse = ", ")),
        dropped_groups = ifelse(length(dropped_groups)==0, "", paste(dropped_groups, collapse = ", ")),
        R = NA_real_, p = NA_real_,
        note = "skip: <2 groups after dropping small groups"
      ))
    }
    
    dist_mat <- phyloseq::distance(ps, method = method, binary = binary)
    fit <- vegan::anosim(dist_mat, grouping = grp, permutations = permutations)
    
    tibble(
      Site = st,
      n_samples = nsamples(ps0),
      n_groups  = length(unique(grp0)),
      kept_groups = paste(sort(unique(grp)), collapse = ", "),
      dropped_groups = ifelse(length(dropped_groups)==0, "", paste(dropped_groups, collapse = ", ")),
      R = unname(fit$statistic),
      p = fit$signif,
      note = ""
    )
  }) %>%
    arrange(desc(R))
}


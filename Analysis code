library(dplyr)
library(tibble)
dfC <- as.data.frame(adon2) %>%
  rownames_to_column("Term") %>%
  filter(Term != "Residual", Term != "Total") %>%
  mutate(
    Term = factor(Term, levels = Term[order(R2, decreasing = TRUE)]),
    sig = case_when(
      `Pr(>F)` <= 0.001 ~ "***",
      `Pr(>F)` <= 0.01  ~ "**",
      `Pr(>F)` <= 0.05  ~ "*",
      `Pr(>F)` <= 0.1   ~ " ",
      TRUE              ~ ""
    ),
    p_label = ifelse(`Pr(>F)` < 0.001, "<0.001", sprintf("%.3f", `Pr(>F)`))
  )
library(ggplot2)

offset <- max(dfC$R2) * 0.025

b <- ggplot(dfC, aes(x = R2, y = Term)) +
  geom_col(width = 0.75) +
  geom_text(
    data = subset(dfC, sig != ""),
    aes(x = R2 + offset, label = sig),
    size = 5,
    hjust = 0
  ) +
  scale_x_continuous(expand = expansion(mult = c(0, 0.18))) +
  labs(x = expression(italic(R)^2), y = NULL) +
  theme_classic(base_size = 14) +
  theme(
    axis.text.y = element_text(size = 12),
    axis.title.x = element_text(size = 14, face = "bold")
  )

b

